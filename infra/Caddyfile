# Caddyfile — reverse proxy com auto-HTTPS para o Lumina backend.
# Auditoria 2026-05-17, crítico #10: backend deixa de expor :8000 direto ao host.
# Caddy termina TLS (Let's Encrypt) e faz proxy para o gunicorn via rede interna.
#
# Variável PROD_DOMAIN é exigida via ${VAR:?...} no docker-compose.prod.yml.

{$PROD_DOMAIN} {
    # Auto-HTTPS via Let's Encrypt (Caddy default).

    # Headers de segurança aplicados pelo proxy (defesa em profundidade
    # mesmo que o Django também os configure).
    header {
        Strict-Transport-Security "max-age=31536000; includeSubDomains; preload"
        X-Content-Type-Options "nosniff"
        X-Frame-Options "DENY"
        Referrer-Policy "strict-origin-when-cross-origin"
        Permissions-Policy "geolocation=(), microphone=(), camera=()"
        # Remove server fingerprinting
        -Server
    }

    # Proxy para o gunicorn na rede interna.
    # Caddy injeta automaticamente: X-Forwarded-For, X-Forwarded-Proto=https, X-Real-IP.
    #
    # ⚠️ Auditoria 2026-05-18 crítico #1 (item 23B novo):
    # Caddy SOBRESCREVE X-Real-IP e X-Forwarded-For com o IP real do cliente,
    # ignorando qualquer valor que o cliente tenha enviado nesses headers.
    # Isso torna X-Real-IP confiável para o rate limit em auth_rate_limit.py.
    # NUNCA remover esse comportamento — o app passa a confiar em header fakeável.
    reverse_proxy web:8000 {
        # Timeout generoso para queries analíticas pesadas (dashboard com aggregate).
        transport http {
            read_timeout 60s
        }
        # Garante que headers de IP venham só do Caddy, não do cliente.
        header_up X-Real-IP {remote_host}
        header_up X-Forwarded-For {remote_host}
    }

    # Logs estruturados (JSON) — facilita ingestão em SIEM/Loki/Cloudwatch.
    log {
        output stdout
        format json
    }
}
