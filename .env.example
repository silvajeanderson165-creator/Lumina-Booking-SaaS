# Lumina Booking SaaS / Analytics SaaS
#
# ⚠️ NÃO commite este arquivo com valores reais. Este é só um template.
# Auditoria 2026-05-17, item 5C: docker-compose.prod.yml exige TODAS as envs
# abaixo via ${VAR:?required}. Se faltar uma, o boot em prod aborta.

# ───────────────────────────────────────────────────────────────────────────────
# Database (PostgreSQL)
# ───────────────────────────────────────────────────────────────────────────────
POSTGRES_DB=lumina_db
POSTGRES_USER=lumina_admin
# ⚠️ NUNCA use "securepassword123" ou variações em produção. Em prod:
#   PROD_DB_PASSWORD="$(openssl rand -base64 32)"
POSTGRES_PASSWORD=trocar-por-senha-forte-gerada-por-csprng
POSTGRES_HOST=db
POSTGRES_PORT=5432

# ───────────────────────────────────────────────────────────────────────────────
# Backend (Django)
# ───────────────────────────────────────────────────────────────────────────────
# ⚠️ Gerar SECRET_KEY via CSPRNG (mínimo 256 bits de entropia real). Exemplo:
#   python -c "import secrets; print(secrets.token_urlsafe(64))"
# NUNCA usar string digitada por humano ou variantes de "change-me-in-production".
# Auditoria 2026-05-17, item 6B (força do secret HS256).
SECRET_KEY=trocar-por-token-csprng-min-256-bits

DEBUG=False
# ⚠️ NUNCA usar "*" em produção. Listar os hosts explicitamente.
ALLOWED_HOSTS=localhost,127.0.0.1,lumina-saas.com

# ───────────────────────────────────────────────────────────────────────────────
# CORS — origens permitidas (separadas por vírgula)
# ───────────────────────────────────────────────────────────────────────────────
CORS_ORIGINS=http://localhost:5173,http://localhost:3000,https://marketing-site-black-pi.vercel.app

# ───────────────────────────────────────────────────────────────────────────────
# Stripe / Hotmart — DECORATIVO nesta versão de portfólio.
# Nenhuma rota de webhook implementada. Ver README → "Escopo desta versão".
# ───────────────────────────────────────────────────────────────────────────────
STRIPE_SECRET_KEY=sk_test_PLACEHOLDER_nao_usado_no_codigo
STRIPE_WEBHOOK_SECRET=whsec_PLACEHOLDER_nao_usado_no_codigo

# ───────────────────────────────────────────────────────────────────────────────
# Frontend (Vite)
# ───────────────────────────────────────────────────────────────────────────────
VITE_API_URL=http://localhost:8000/graphql
